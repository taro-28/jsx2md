{
  "name": "jsx2md-monorepo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r --sort run build",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm knip && pnpm build && pnpm smoke && pnpm size",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "knip": "knip",
    "lint": "node scripts/lint.mjs",
    "size": "node scripts/check-size.mjs",
    "smoke": "node scripts/smoke.mjs",
    "test": "vitest run",
    "typecheck": "tsc -b --clean && tsc -b && tsc -p tsconfig.test.json --noEmit && tsc -b --clean && rm -rf packages/core/dist packages/github/dist packages/migrate/dist packages/cli/dist"
  },
  "devDependencies": {
    "@jsx2md/cli": "workspace:*",
    "@jsx2md/github": "workspace:*",
    "@jsx2md/migrate": "workspace:*",
    "@tsconfig/strictest": "2.0.8",
    "@types/mdast": "4.0.4",
    "@types/node": "25.6.0",
    "jsx2md": "workspace:*",
    "knip": "6.6.3",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.22.0",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.0.14"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.15.1"
}
