{
  "name": "@jsx2md/migrate",
  "version": "0.0.1",
  "description": "Convert Markdown files to jsx2md TSX documents.",
  "keywords": [
    "jsx",
    "markdown",
    "migration",
    "tsx"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean --tsconfig tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@jsx2md/github": "workspace:*",
    "jsx2md": "workspace:*",
    "mdast-util-to-markdown": "2.1.2",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "unified": "11.0.5"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
