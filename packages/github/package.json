{
  "name": "@jsx2md/github",
  "version": "0.0.1",
  "description": "GitHub-specific Markdown components and adapters for jsx2md.",
  "keywords": [
    "gfm",
    "github",
    "jsx",
    "markdown"
  ],
  "homepage": "https://github.com/taro-28/jsx2md#readme",
  "bugs": {
    "url": "https://github.com/taro-28/jsx2md/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taro-28/jsx2md.git",
    "directory": "packages/github"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rm -rf dist && tsup src/index.ts --format esm --dts --sourcemap --clean --tsconfig tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "jsx2md": "workspace:*"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
