{
  "name": "jsx2md",
  "version": "0.0.1",
  "description": "Generate Markdown from typed JSX and TSX without React.",
  "keywords": [
    "gfm",
    "github",
    "jsx",
    "markdown",
    "tsx"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "import": "./dist/jsx-dev-runtime.js"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rm -rf dist && tsup src/index.ts src/jsx-runtime.ts src/jsx-dev-runtime.ts src/adapters.ts --format esm --dts --sourcemap --clean --tsconfig tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
