{
  "name": "@jsx2md/cli",
  "version": "0.0.1",
  "description": "CLI for rendering jsx2md TSX documents and migrating Markdown.",
  "keywords": [
    "cli",
    "jsx",
    "markdown",
    "tsx"
  ],
  "homepage": "https://github.com/taro-28/jsx2md#readme",
  "bugs": {
    "url": "https://github.com/taro-28/jsx2md/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taro-28/jsx2md.git",
    "directory": "packages/cli"
  },
  "bin": {
    "jsx2md": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rm -rf dist && tsup src/index.ts --format esm --dts --sourcemap --clean --tsconfig tsconfig.build.json && tsup src/cli.ts src/entry-runner.ts --format esm --sourcemap --tsconfig tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@jsx2md/migrate": "workspace:*",
    "commander": "14.0.3",
    "jsx2md": "workspace:*",
    "tsx": "4.22.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
